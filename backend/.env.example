# =============================================================================
# CONFIGURACIÓN DE ENTORNO - CLUB DEPORTIVO AJAX
# =============================================================================
# Duplica este archivo como .env y ajusta los valores según tu entorno.
# .env está en .gitignore - NUNCA commitees credenciales reales.
# =============================================================================

# --- Base de datos ---
# Produccion (Neon PostgreSQL)
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-dark-meadow-anyl6tb3.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require
# Local (SQLite)
DATABASE_URL=sqlite:///./ajax_local.db

# --- JWT ---
SECRET_KEY=ajax_secret_key_2026_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Storage (Cloudinary) ---
# Si no se configura, usa almacenamiento local en uploads/
# CLOUDINARY_CLOUD_NAME=tu_cloud_name
# CLOUDINARY_API_KEY=tu_api_key
# CLOUDINARY_API_SECRET=tu_api_secret
STORAGE_BUCKET=ajax-uploads

# --- Email (Resend) ---
# Descomentar SOLO si vas a probar emails en local
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM=onboarding@resend.dev
FRONTEND_URL=http://localhost:5173
RESET_TOKEN_EXPIRE_HOURS=1
